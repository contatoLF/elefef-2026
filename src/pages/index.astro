---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

const WA = 'https://api.whatsapp.com/send?phone=5511940635670';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Gestão de Tráfego Pago",
  "provider": {
    "@type": "Organization",
    "name": "Agência Elefef",
    "url": "https://elefef.com.br"
  },
  "serviceType": "Gestão de Anúncios Online",
  "description": "Gestão estratégica de campanhas em Google Ads, Meta Ads, Shopee Ads, Amazon Ads, TikTok Ads e Globo Ads para e-commerces, negócios locais e candidatos políticos.",
  "areaServed": { "@type": "Country", "name": "Brasil" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Plataformas de Anúncios",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Google Ads" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Meta Ads" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Amazon Ads" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Shopee Ads" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "TikTok Ads" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Globo Ads" } }
    ]
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Agência Elefef",
  "@id": "https://elefef.com.br",
  "url": "https://elefef.com.br",
  "logo": "https://elefef.com.br/images/Copia-de-Copia-de-elefef.png",
  "image": "https://elefef.com.br/images/og-elefef.png",
  "description": "Agência de performance especializada em gestão de tráfego pago: Google Ads, Meta Ads, Amazon Ads, Shopee Ads, Bing Ads e Globo Ads. Soluções completas para e-commerce e marketing político digital.",
  "telephone": "+55-11-94063-5670",
  "priceRange": "$$",
  "currenciesAccepted": "BRL",
  "paymentAccepted": "Transferência bancária, PIX",
  "address": { "@type": "PostalAddress", "addressLocality": "São Paulo", "addressRegion": "SP", "addressCountry": "BR" },
  "foundingDate": "2022",
  "numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 1, "maxValue": 10 },
  "sameAs": ["https://www.instagram.com/elefef", "https://www.facebook.com/elefef"]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Como a Elefef pode ajudar meu negócio?", "acceptedAnswer": { "@type": "Answer", "text": "A Elefef traz soluções personalizadas que elevam a visibilidade do seu negócio. Nossas estratégias focadas em tráfego pago são projetadas para atrair mais clientes e maximizar resultados. Não buscamos ser a maior agência do mercado, mas sim a mais eficiente e próxima dos clientes." } },
    { "@type": "Question", "name": "Quais plataformas de anúncios vocês gerenciam?", "acceptedAnswer": { "@type": "Answer", "text": "Trabalhamos com Google Ads, Meta Ads (Facebook e Instagram), TikTok Ads, Shopee Ads, Amazon Ads, Bing Ads e Globo Ads. Aproveitamos o melhor de cada plataforma para conectar seu negócio ao público-alvo certo." } },
    { "@type": "Question", "name": "A conta de anúncios fica no meu nome ou no da agência?", "acceptedAnswer": { "@type": "Answer", "text": "Sempre no seu nome. A conta de anúncios é 100% do cliente. Você tem acesso total a todas as plataformas, campanhas e dados. Nada fica retido na agência — garantia de transparência total." } },
    { "@type": "Question", "name": "Qual o prazo para ver resultados?", "acceptedAnswer": { "@type": "Answer", "text": "Os primeiros resultados costumam aparecer nas primeiras semanas, mas o desempenho pleno se consolida em 60 a 90 dias de otimização contínua. O prazo varia conforme a estratégia, nicho e histórico da conta." } },
    { "@type": "Question", "name": "Há multa para cancelar o contrato?", "acceptedAnswer": { "@type": "Answer", "text": "Não cobramos multa de rescisão. Trabalhamos com contratos mensais e acreditamos que resultado é a melhor forma de fidelizar um cliente. Se não estiver satisfeito, você pode encerrar o contrato sem penalidades." } },
    { "@type": "Question", "name": "O investimento em mídia passa pela agência?", "acceptedAnswer": { "@type": "Answer", "text": "Não. O investimento em mídia paga é feito diretamente pelo cliente à plataforma (Google, Meta, Amazon, etc.). A Elefef cobra apenas a taxa de gestão. Isso garante total transparência e facilita a prestação de contas, inclusive para campanhas eleitorais." } }
  ]
};
---

<BaseLayout
  title="Agência Elefef – Gestão de Tráfego Pago e Soluções para E-commerce"
  description="Agência especializada em gestão de tráfego pago (Google Ads, Meta Ads, Shopee Ads, Amazon Ads, Bing Ads, Globo Ads) e soluções completas para e-commerce e marketing político. Transformamos cliques em clientes."
  schema={[serviceSchema, localBusinessSchema, faqSchema]}
>
  <Header />

  <main>
    <!-- ══ HERO ══ -->
    <section class="bg-azul pt-[140px] pb-20 overflow-hidden relative">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 70% 50%, rgba(21,230,245,.12) 0%, transparent 60%);"></div>
      <div class="container relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <span class="section-tag light">Agência de Performance</span>
            <h1 class="text-white font-heading font-bold mt-3 mb-5" style="font-size:clamp(30px,4.5vw,50px);line-height:1.2;">
              A melhor forma de encontrar seu cliente é ser <em class="not-italic text-ciano">encontrado por ele…</em>
            </h1>
            <p class="text-white/85 text-[17px] mb-9 max-w-lg">
              Descubra como nossa experiência em gestão de tráfego pago pode transformar sua visibilidade no ambiente digital. Transformamos cliques em clientes para vender todo santo dia!
            </p>
            <div class="flex gap-3.5 flex-wrap">
              <a href={`${WA}&text=Ol%C3%A1%2C%20gostaria%20de%20conversar%20sobre%20gest%C3%A3o%20de%20tr%C3%A1fego`} class="btn btn-ciano btn-lg" target="_blank" rel="noopener">Vamos conversar</a>
              <a href="/orcamento" class="btn btn-outline btn-lg">Solicite Orçamento</a>
            </div>
          </div>
          <div class="hidden md:block rounded-2xl overflow-hidden">
            <!-- PLACEHOLDER: hero-trafego-ecommerce.webp — imagem de dashboard de campanhas ou equipe trabalhando -->
            <img
              src="/images/banner-site-eleef-novo-1024x545.png"
              alt="Gestão de Tráfego Pago — Agência Elefef"
              class="w-full rounded-2xl"
              width="560"
              height="380"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ══ STATS BAR ══ -->
    <div class="bg-azul-dark py-7">
      <div class="container">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          <div>
            <strong class="block font-heading text-3xl font-bold text-ciano">10+ anos</strong>
            <span class="text-white/80 text-sm">de experiência em marketing digital</span>
          </div>
          <div>
            <strong class="block font-heading text-3xl font-bold text-ciano">30+ lojas</strong>
            <span class="text-white/80 text-sm">de e-commerce implantadas</span>
          </div>
          <div>
            <strong class="block font-heading text-3xl font-bold text-ciano">6 plataformas</strong>
            <span class="text-white/80 text-sm">de anúncios gerenciadas</span>
          </div>
          <div>
            <strong class="block font-heading text-3xl font-bold text-ciano">2022</strong>
            <span class="text-white/80 text-sm">fundação da agência</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ══ MISSÃO ══ -->
    <section class="section">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div class="rounded-2xl overflow-hidden">
            <!-- PLACEHOLDER: missao-elefef.webp — foto do Luiz ou equipe em reunião -->
            <img
              src="/images/Gestao-de-trafego-para-negocios-locais-1024x1024.png"
              alt="Nossa Missão — Agência Elefef"
              class="w-full rounded-2xl"
              width="520"
              height="520"
              loading="lazy"
            />
          </div>
          <div>
            <span class="section-tag">Nossa Missão</span>
            <div class="divider left"></div>
            <h2 class="font-heading font-semibold text-[#1a1a1a] mb-4" style="font-size:clamp(24px,3vw,34px);">
              Proporcionar soluções eficazes que transformam negócios
            </h2>
            <p class="text-texto text-base mb-3.5">
              Nosso objetivo é proporcionar soluções eficazes em gestão de tráfego pago, ajudando negócios locais e e-commerces a se destacarem no mercado.
            </p>
            <p class="text-texto text-base mb-5">
              Acreditamos que cada cliente merece uma <strong class="text-[#1a1a1a] font-semibold">estratégia única</strong> que amplifique sua presença online e atraia mais consumidores. Não buscamos ser a maior agência do mercado, mas sim a mais eficiente e próxima dos clientes.
            </p>
            <ul class="feature-list mb-7">
              <li>
                <span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                Estratégia personalizada para cada negócio
              </li>
              <li>
                <span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                Relatórios detalhados com ROI real
              </li>
              <li>
                <span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                Suporte contínuo e consultoria especializada
              </li>
              <li>
                <span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                Experiência em e-commerce e negócios locais
              </li>
            </ul>
            <a href="/quem-somos" class="btn btn-primary">Conheça a agência</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ CTA AGENDAR ══ -->
    <section class="cta-banner">
      <div class="container">
        <h2>Pronto para <span>impulsionar seu negócio?</span></h2>
        <p>Nossa expertise em tráfego pago transforma cliques em clientes reais. Receba uma análise gratuita do seu potencial de crescimento!</p>
        <div class="flex gap-4 justify-center flex-wrap mt-8">
          <a href={`${WA}&text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20reuni%C3%A3o`} class="btn btn-ciano btn-lg" target="_blank" rel="noopener">Agende agora</a>
          <a href="/orcamento" class="btn btn-outline btn-lg">Solicite Orçamento</a>
        </div>
      </div>
    </section>

    <!-- ══ GESTÃO DE TRÁFEGO ══ -->
    <section class="section bg-cinza-bg">
      <div class="container">
        <div class="text-center mb-12">
          <span class="section-tag">Nossas Plataformas</span>
          <div class="divider"></div>
          <h2 class="section-title">Gestão de <span>Tráfego Pago</span></h2>
          <p class="section-sub">Pare de queimar dinheiro com anúncios que não convertem! Gerenciamos suas campanhas nas principais plataformas para maximizar resultados.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7">
          <div class="platform-card">
            <img src="/images/google-ads-para-negocios-locais.png" alt="Google Ads — Agência Elefef" class="w-full max-h-[120px] object-contain mx-auto mb-4" loading="lazy" />
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-base mb-2">Google Ads</h3>
            <p class="text-[13.5px] text-texto mb-4">Dê visibilidade ao seu negócio com campanhas direcionadas que atraem clientes qualificados no momento certo.</p>
            <a href="/google-ads-ecommerce" class="card-link">Saiba mais →</a>
          </div>
          <div class="platform-card">
            <img src="/images/facebook-instagram-para-negocios-locais.png" alt="Meta Ads — Agência Elefef" class="w-full max-h-[120px] object-contain mx-auto mb-4" loading="lazy" />
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-base mb-2">Meta Ads</h3>
            <p class="text-[13.5px] text-texto mb-4">Conecte-se com seu público onde ele passa a maior parte do tempo online através de anúncios eficazes.</p>
            <a href="/meta-ads-ecommerce" class="card-link">Saiba mais →</a>
          </div>
          <div class="platform-card">
            <img src="/images/shopee-ads.jpeg" alt="Shopee Ads — Agência Elefef" class="w-full max-h-[120px] object-contain mx-auto mb-4" loading="lazy" />
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-base mb-2">Shopee Ads</h3>
            <p class="text-[13.5px] text-texto mb-4">Maximize seus resultados no maior marketplace do Brasil com segmentação e otimização de ACOS.</p>
            <a href="/shopee-ads" class="card-link">Saiba mais →</a>
          </div>
          <div class="platform-card">
            <!-- PLACEHOLDER: tiktok-ads-elefef.webp -->
            <img src="/images/3.png" alt="TikTok Ads — Agência Elefef" class="w-full max-h-[120px] object-contain mx-auto mb-4" loading="lazy" />
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-base mb-2">TikTok Ads</h3>
            <p class="text-[13.5px] text-texto mb-4">Faça sua marca crescer com anúncios no TikTok. Aumente as vendas, impulsione as conversões e atraia clientes.</p>
            <a href="/tiktok-ads" class="card-link">Saiba mais →</a>
          </div>
          <div class="platform-card">
            <img src="/images/gestao-de-trafego-local-2.png" alt="Globo Ads — Agência Elefef" class="w-full max-h-[120px] object-contain mx-auto mb-4" loading="lazy" />
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-base mb-2">Globo Ads</h3>
            <p class="text-[13.5px] text-texto mb-4">Com 25 milhões de usuários mensais, a Globo Ads oferece alcance inigualável para um público amplo e diversificado.</p>
            <a href="/globo-ads" class="card-link">Saiba mais →</a>
          </div>
          <div class="platform-card">
            <img src="/images/amazon-ads-gestao-trafego.png" alt="Amazon Ads — Agência Elefef" class="w-full max-h-[120px] object-contain mx-auto mb-4" loading="lazy" />
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-base mb-2">Amazon Ads</h3>
            <p class="text-[13.5px] text-texto mb-4">Aumente a visibilidade e impulsione suas vendas com nossa gestão estratégica de Amazon Ads.</p>
            <a href="/amazon-ads" class="card-link">Saiba mais →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ DIFERENCIAIS / QUEBRA DE OBJEÇÃO ══ -->
    <section class="section">
      <div class="container">
        <div class="text-center mb-12">
          <span class="section-tag">Por que a Elefef?</span>
          <div class="divider"></div>
          <h2 class="section-title">Transparência total — <span>sem letras miúdas</span></h2>
          <p class="section-sub">Esses são os pilares que nos diferenciam de qualquer outra agência de tráfego pago.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7">
          <div class="card">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Conta sempre no seu nome</h3>
            <p class="text-[14.5px] text-texto">A conta de anúncios é 100% sua. Você tem acesso completo a Google Ads, Meta Business, Amazon Ads — nada fica retido na agência.</p>
          </div>
          <div class="card">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Mídia paga direto à plataforma</h3>
            <p class="text-[14.5px] text-texto">O investimento em anúncios vai direto da sua conta para o Google, Meta ou outra plataforma. Nada passa pela agência.</p>
          </div>
          <div class="card">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Nota fiscal em tudo</h3>
            <p class="text-[14.5px] text-texto">Todos os serviços emitidos com nota fiscal. Sem informalidade, sem surpresa no fim do mês.</p>
          </div>
          <div class="card">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Sem multa de rescisão</h3>
            <p class="text-[14.5px] text-texto">Contratos mensais, sem fidelidade forçada. Se não estiver satisfeito, você pode encerrar sem penalidade alguma.</p>
          </div>
          <div class="card">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Relatórios reais com ROI</h3>
            <p class="text-[14.5px] text-texto">Nenhuma métrica de vaidade. Mostramos o retorno real sobre o investimento em cada relatório mensal.</p>
          </div>
          <div class="card">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Atendimento próximo e dedicado</h3>
            <p class="text-[14.5px] text-texto">Não somos uma agência de prateleira. Cada cliente tem atendimento dedicado via WhatsApp, sem fila de suporte.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ SOLUÇÕES E-COMMERCE ══ -->
    <section class="section bg-cinza-bg">
      <div class="container">
        <div class="text-center mb-12">
          <span class="section-tag">Soluções Completas</span>
          <div class="divider"></div>
          <h2 class="section-title">Tudo que seu <span>E-commerce</span> precisa</h2>
          <p class="section-sub">Da implantação à gestão completa, oferecemos soluções end-to-end para lojas virtuais de todos os portes.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7">
          <a href="/consultoria-ecommerce" class="card block" style="text-decoration:none;">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Consultoria em E-commerce</h3>
            <p class="text-[14.5px] text-texto mb-4">Diagnóstico completo do ponto A ao ponto B. Planejamento detalhado com prazos e custos reais.</p>
            <span class="card-link">Ver serviço →</span>
          </a>
          <a href="/implantacao-ecommerce" class="card block" style="text-decoration:none;">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Implantação em 14 dias</h3>
            <p class="text-[14.5px] text-texto mb-4">Implantamos sua loja virtual em apenas 14 dias em NuvemShop, Loja Integrada, Shopify ou Tray.</p>
            <span class="card-link">Ver serviço →</span>
          </a>
          <a href="/suporte-evolucao" class="card block" style="text-decoration:none;">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="font-heading font-semibold text-[#1a1a1a] text-[17px] mb-2.5">Suporte e Evolução</h3>
            <p class="text-[14.5px] text-texto mb-4">Mantenha sua loja sempre atualizada, segura e evoluindo com nosso suporte especializado.</p>
            <span class="card-link">Ver serviço →</span>
          </a>
          <a href="/seo-ecommerce" class="card block" style="text-decoration:none;">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
