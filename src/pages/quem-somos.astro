---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Quem Somos – Agência Elefef",
  "description": "Conheça a Agência Elefef e Luiz Freitas, Coordenador de Tráfego e Consultor de E-commerce com mais de 10 anos de experiência em marketing digital.",
  "url": "https://elefef.com.br/quem-somos",
  "mainEntity": {
    "@type": "Organization",
    "name": "Agência Elefef",
    "url": "https://elefef.com.br",
    "founder": {
      "@type": "Person",
      "name": "Luiz Felipe Freitas",
      "jobTitle": "Coordenador de Tráfego & Consultor de E-commerce"
    }
  }
};
---
<BaseLayout
  title="Quem Somos – Agência Elefef"
  description="Conheça a Agência Elefef e Luiz Freitas, Coordenador de Tráfego e Consultor de E-commerce com mais de 10 anos de experiência em marketing digital."
  canonical="https://elefef.com.br/quem-somos"
  schema={schema}
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="page-hero">
      <div class="container">
        <p class="section-tag light">A Agência</p>
        <h1>Quem Somos</h1>
        <p>Nascemos com o propósito de oferecer soluções estratégicas e personalizadas em gestão de tráfego pago e e-commerce.</p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:8px;">
          <a href="/orcamento" class="btn btn-ciano btn-lg">Solicitar Orçamento</a>
          <a href="https://api.whatsapp.com/send?phone=5511940635670&text=Ol%C3%A1%2C%20gostaria%20de%20falar%20no%20WhatsApp" class="btn btn-outline btn-lg" target="_blank" rel="noopener">Falar no WhatsApp</a>
        </div>
      </div>
    </section>

    <!-- SOBRE LUIZ -->
    <section class="section">
      <div class="container">
        <div class="feature-grid">
          <div class="feature-img">
            <img src="/images/Luiz-Freitas-Gestor-de-trafego-pago-senior.png" alt="Luiz Freitas – Coordenador de Tráfego" loading="lazy">
          </div>
          <div class="feature-content">
            <span class="section-tag">Fundador</span>
            <div class="divider left"></div>
            <h2>Luiz Felipe Freitas</h2>
            <p style="font-size:14px;color:var(--azul);font-weight:600;margin-bottom:16px;">Coordenador de Tráfego &amp; Consultor de E-commerce</p>
            <p>Com mais de <strong>10 anos de experiência</strong> em marketing digital, Luiz coordenou equipes de mídia em e-commerces de moda, trabalhou em agências de performance e gerenciou operações complexas de e-commerce.</p>
            <p>Sua trajetória inclui passagens por projetos em <strong>Vtex, Nuvemshop, Loja Integrada, Tray Commerce, WooCommerce, Magento e Shopify</strong>, além de coordenação de equipes de mídia paga.</p>
            <ul class="feature-list">
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Certificações Google Ads e Meta Blueprint</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Parceiro Tray Commerce e NuvemShop</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>MBA em Gestão de Projetos — USP</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Graduação pela FATEC-Santos</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Marketing digital desde 2014</li>
            </ul>
            <a href="/orcamento" class="btn btn-primary">Fale com a gente</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FILOSOFIA -->
    <section class="section bg-cinza">
      <div class="container">
        <div class="text-center">
          <span class="section-tag">Nossa Filosofia</span>
          <div class="divider"></div>
          <h2 class="section-title">Eficiência e <span>proximidade</span> acima de tudo</h2>
          <p class="section-sub">Não buscamos ser a maior agência do mercado, mas sim a mais eficiente e próxima dos clientes.</p>
        </div>
        <div class="cards-grid">
          <div class="card text-center">
            <div class="card-icon" style="margin:0 auto 20px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3>Atendimento Personalizado</h3>
            <p>Cada cliente recebe atenção dedicada. Entendemos profundamente seu negócio antes de criar qualquer estratégia.</p>
          </div>
          <div class="card text-center">
            <div class="card-icon" style="margin:0 auto 20px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3>Foco em Resultados</h3>
            <p>Não trabalhamos com vaidade de métricas. Nosso norte é o resultado real: mais vendas e maior retorno sobre investimento.</p>
          </div>
          <div class="card text-center">
            <div class="card-icon" style="margin:0 auto 20px;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            </div>
            <h3>Transparência Total</h3>
            <p>Relatórios detalhados, acesso completo às plataformas e comunicação clara em todas as etapas do trabalho.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA INTERMEDIÁRIO -->
    <section class="cta-banner">
      <div class="container">
        <h2>Seu cliente ideal está a um clique de distância... <span>Levamos ele até você!</span></h2>
        <p>Conte com uma agência que entende profundamente o seu segmento e entrega resultado real.</p>
        <div class="cta-btns">
          <a href="/orcamento" class="btn btn-ciano btn-lg">Solicite Orçamento</a>
          <a href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ26OVSaC3Wj8BBjx4Kyi_3huca82hVkME4HDNohzX53kWFc1EJ2sbNDVSHa8-nVmznITv0BbAxD" class="btn btn-outline btn-lg" target="_blank" rel="noopener">Agendar Reunião</a>
        </div>
      </div>
    </section>

    <!-- EXPERTISE -->
    <section class="section">
      <div class="container">
        <div class="feature-grid">
          <div class="feature-content">
            <span class="section-tag">Expertise &amp; Experiência</span>
            <div class="divider left"></div>
            <h2>Plataformas em que trabalhamos</h2>
            <p>Nossa experiência abrange as principais plataformas de e-commerce e anúncios do mercado brasileiro e mundial.</p>
            <ul class="feature-list">
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Google Ads — Search, Display, Shopping, YouTube, Max Performance</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Meta Ads — Facebook, Instagram e Audience Network</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>TikTok Ads, Bing Ads e Globo Ads</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Shopee Ads</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Amazon Ads</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>NuvemShop, Loja Integrada, Tray, Shopify, WooCommerce, Vtex, Magento</li>
            </ul>
            <a href="/gestao-de-trafego" class="btn btn-primary">Ver serviços de tráfego</a>
          </div>
          <div class="feature-img">
            <img src="/images/consultor-em-ecommerce.png" alt="Expertise em E-commerce" loading="lazy">
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-banner">
      <div class="container">
        <h2>Seu cliente ideal está a um clique de distância... <span>Levamos ele até você!</span></h2>
        <p>Conte com uma agência que entende profundamente o seu segmento e entrega resultado real.</p>
        <div class="cta-btns">
          <a href="/orcamento" class="btn btn-ciano btn-lg">Solicite Orçamento</a>
          <a href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ26OVSaC3Wj8BBjx4Kyi_3huca82hVkME4HDNohzX53kWFc1EJ2sbNDVSHa8-nVmznITv0BbAxD" class="btn btn-outline btn-lg" target="_blank" rel="noopener">Agendar Reunião</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
  <WhatsAppFloat />
</BaseLayout>
