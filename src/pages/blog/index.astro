---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFormatter = new Intl.DateTimeFormat('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' });

const categories = [...new Set(posts.map(p => p.data.category))];

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog da Agência Elefef",
  "url": "https://elefef.com.br/blog",
  "description": "Artigos sobre tráfego pago, Google Ads, Meta Ads, e-commerce, Amazon Ads, Shopee Ads e marketing político digital.",
  "publisher": {
    "@type": "Organization",
    "name": "Agência Elefef",
    "logo": { "@type": "ImageObject", "url": "https://elefef.com.br/images/Copia-de-Copia-de-elefef.png" }
  }
};
---

<BaseLayout
  title="Blog — Tráfego Pago, E-commerce e Marketing Digital | Agência Elefef"
  description="Artigos sobre gestão de tráfego pago, Google Ads, Meta Ads, Amazon Ads, Shopee Ads, e-commerce e marketing político digital. Conteúdo prático para donos de negócio e candidatos."
  schema={blogSchema}
>
  <Header />

  <main>
    <!-- Hero do blog -->
    <section class="page-hero">
      <div class="container">
        <span class="section-tag light">Blog</span>
        <h1>Conteúdo sobre <em class="not-italic text-ciano">Tráfego Pago</em> e E-commerce</h1>
        <p>Artigos práticos para ajudar donos de negócio, e-commerces e candidatos políticos a crescerem com anúncios eficientes.</p>
      </div>
    </section>

    <!-- Grid de artigos -->
    <section class="section">
      <div class="container">

        <!-- Filtro por categoria (estático — JS simples) -->
        {categories.length > 1 && (
          <div class="flex flex-wrap gap-2 mb-10 justify-center" id="category-filters">
            <button class="cat-btn active px-4 py-1.5 rounded-full text-sm font-heading font-medium transition-all" data-cat="all">Todos</button>
            {categories.map(cat => (
              <button class="cat-btn px-4 py-1.5 rounded-full text-sm font-heading font-medium transition-all" data-cat={cat}>{cat}</button>
            ))}
          </div>
        )}

        <!-- Grid de posts -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
          {posts.map(post => (
            <article class="post-card bg-white border border-borda rounded-xl overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,.10)]" data-category={post.data.category}>
              {post.data.image ? (
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt ?? post.data.title}
                  class="w-full h-48 object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-48 bg-gradient-to-br from-azul to-accent flex items-center justify-center">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.5)" stroke-width="1"><path d="M4 4h16v16H4z"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center gap-2 mb-3">
                  <span class="bg-[#f0f6ff] text-azul text-xs px-3 py-1 rounded-full font-heading font-medium">{post.data.category}</span>
                  <time class="text-[12px] text-[#999]" datetime={post.data.pubDate.toISOString()}>
                    {dateFormatter.format(post.data.pubDate)}
                  </time>
                </div>
                <h2 class="font-heading font-semibold text-[#1a1a1a] text-[17px] leading-snug mb-2.5 line-clamp-2">
                  {post.data.title}
                </h2>
                <p class="text-texto text-sm leading-relaxed mb-4 line-clamp-3">{post.data.description}</p>
                <a href={`/blog/${post.slug}`} class="card-link text-sm">
                  Ler artigo completo →
                </a>
              </div>
            </article>
          ))}
        </div>

        {posts.length === 0 && (
          <p class="text-center text-texto text-lg py-20">Em breve novos artigos. Acompanhe!</p>
        )}
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-banner">
      <div class="container">
        <h2>Quer colocar o aprendizado em <span>prática?</span></h2>
        <p>Fale com a Elefef e receba uma análise gratuita das suas campanhas de tráfego pago.</p>
        <div class="flex gap-4 justify-center flex-wrap mt-8">
          <a href="https://api.whatsapp.com/send?phone=5511940635670&text=Ol%C3%A1%2C%20li%20o%20blog%20e%20gostaria%20de%20conversar" class="btn btn-ciano btn-lg" target="_blank" rel="noopener">Falar no WhatsApp</a>
          <a href="/orcamento" class="btn btn-outline btn-lg">Solicitar Orçamento</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>

<style>
  .cat-btn {
    background: #f0f6ff;
    color: #1E73BE;
    border: 2px solid transparent;
  }
  .cat-btn:hover, .cat-btn.active {
    background: #1E73BE;
    color: #fff;
  }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.dataset.cat;
      cards.forEach(card => {
        card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
      });
    });
  });
</script>
