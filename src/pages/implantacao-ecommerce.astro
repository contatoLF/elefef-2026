<style>
  /* PLATAFORMAS BAR */
  .plataformas-bar {
    background: #fff;
    border-top: 1px solid var(--borda);
    border-bottom: 1px solid var(--borda);
    padding: 20px 0;
  }
  .plataformas-bar-label {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
