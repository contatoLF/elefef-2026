    margin-bottom: 14px;
  }
  .plataformas-bar-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px 32px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .plataformas-bar-list li {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 14px;
    font-weight: 600;
    color: var(--escuro);
  }
  .plataformas-bar-list svg { color: var(--azul); }

  /* DORES GRID — 2 colunas */
  .dores-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  /* INCLUSO GRID — 4 colunas */
  .incluso-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  .incluso-item {
    background: #fff;
    border: 1px solid var(--borda);
    border-radius: var(--radius);
    padding: 22px 18px;
    transition: box-shadow var(--trans), transform var(--trans);
  }
  .incluso-item:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,.08);
    transform: translateY(-3px);
  }
  .incluso-icon {
    width: 44px;
    height: 44px;
    background: #f0f6ff;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
  .incluso-item h3 {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--escuro);
    margin-bottom: 6px;
  }
  .incluso-item p {
    font-size: 13px;
    color: var(--texto);
    line-height: 1.6;
  }

  /* TIMELINE — 4 colunas, 2 linhas */
  .timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 48px;
  }
  .tl-item {
    background: #fff;
    border: 1px solid var(--borda);
    border-radius: var(--radius);
    padding: 22px 18px;
    text-align: center;
  }
  .tl-destaque {
    border-color: var(--ciano);
    box-shadow: 0 4px 16px rgba(21,230,245,.18);
  }
  .tl-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 5px 14px;
    border-radius: 50px;
    background: var(--azul);
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .tl-badge-ciano {
    background: var(--ciano);
    color: #003d47;
  }
  .tl-item h3 {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--escuro);
    margin-bottom: 7px;
  }
  .tl-item p {
    font-size: 12.5px;
    color: var(--texto);
    line-height: 1.6;
  }

  /* PLATFORM GRID — 4 colunas */
  .platform-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  /* STATS ROW — 4 colunas */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }
  .stat-box {
    text-align: center;
    background: #fff;
    border: 1px solid var(--borda);
    border-radius: var(--radius);
    padding: 28px 16px;
  }
  .stat-box strong {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 30px;
    font-weight: 700;
    color: var(--azul);
    line-height: 1.1;
  }
  .stat-box span {
    display: block;
    font-size: 13px;
    color: var(--texto);
    margin-top: 6px;
  }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .incluso-grid    { grid-template-columns: repeat(2, 1fr); }
    .timeline        { grid-template-columns: repeat(2, 1fr); }
    .platform-grid   { grid-template-columns: repeat(2, 1fr); }
    .stats-row       { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .dores-grid      { grid-template-columns: 1fr; }
    .incluso-grid    { grid-template-columns: 1fr; }
    .timeline        { grid-template-columns: 1fr; }
    .platform-grid   { grid-template-columns: 1fr; }
  }
</style>
