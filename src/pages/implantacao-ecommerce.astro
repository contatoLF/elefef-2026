---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Implantação de E-commerce",
  "provider": { "@type": "Organization", "name": "Agência Elefef", "url": "https://elefef.com.br" },
  "description": "Implantamos sua loja virtual em apenas 14 dias na NuvemShop, Loja Integrada, Shopify ou Tray. Briefing, design, integrações, cadastro de produtos e treinamento.",
  "areaServed": { "@type": "Country", "name": "Brasil" }
};
---
<BaseLayout
  title="Implantação de E-commerce em 14 dias – Agência Elefef"
  description="Implantamos sua loja virtual em apenas 14 dias na NuvemShop, Loja Integrada, Shopify ou Tray. Briefing, design, integrações, cadastro de produtos e treinamento."
  canonical="https://elefef.com.br/implantacao-ecommerce"
  schema={schema}
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="page-hero">
      <div class="container">
        <p class="section-tag light">Soluções E-commerce</p>
        <h1>Implantamos sua loja virtual em apenas <span style="color:var(--ciano);">14 dias</span></h1>
        <p>Da escolha da plataforma ao cadastro de produtos, cuide do seu negócio enquanto nós cuidamos da sua loja.</p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:8px;">
          <a href="/orcamento" class="btn btn-ciano btn-lg">Solicitar Orçamento</a>
          <a href="https://api.whatsapp.com/send?phone=5511940635670&text=Ol%C3%A1%2C%20gostaria%20de%20falar%20no%20WhatsApp" class="btn btn-outline btn-lg" target="_blank" rel="noopener">Falar no WhatsApp</a>
        </div>
      </div>
    </section>

    <!-- STATS BAR -->
    <div class="stats-bar">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item"><strong>14 dias</strong><span>prazo de implantação</span></div>
          <div class="stat-item"><strong>30+</strong><span>lojas implantadas</span></div>
          <div class="stat-item"><strong>5h</strong><span>de treinamento incluídas</span></div>
          <div class="stat-item"><strong>4</strong><span>plataformas disponíveis</span></div>
        </div>
      </div>
    </div>

    <!-- IMPLANTAÇÃO COMPLETA -->
    <section class="section">
      <div class="container">
        <div class="feature-grid">
          <div class="feature-img">
            <img src="/images/implementacao-de-loja-virtual-1.png" alt="Implantação de E-commerce" loading="lazy">
          </div>
          <div class="feature-content">
            <span class="section-tag">Implantação completa</span>
            <div class="divider left"></div>
            <h2>Sua loja do zero ao primeiro venda em 14 dias</h2>
            <p>Nossa metodologia de implantação garante que sua loja esteja completamente configurada, com produtos cadastrados e pronta para vender em apenas duas semanas.</p>
            <ul class="feature-list">
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Briefing completo e escolha estratégica da plataforma</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Arquitetura de navegação e filtros</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Design personalizado com tema otimizado</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Configuração de ERP e integrações</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Cadastro de produtos com SEO</li>
              <li><span class="check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>Fotografia de produtos e treinamento</li>
            </ul>
            <a href="/orcamento" class="btn btn-primary">Quero minha loja em 14 dias</a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-banner">
      <div class="container">
        <h2>Sua loja virtual em <span>14 dias, garantido.</span></h2>
        <p>Solicite um orçamento e receba uma proposta personalizada para a implantação do seu e-commerce.</p>
        <div class="cta-btns">
          <a href="/orcamento" class="btn btn-ciano btn-lg">Solicitar Orçamento</a>
          <a href="https://api.whatsapp.com/send?phone=5511940635670&text=Ol%C3%A1%2C%20gostaria%20de%20falar%20no%20WhatsApp" class="btn btn-outline btn-lg" target="_blank" rel="noopener">Falar no WhatsApp</a>
        </div>
      </div>
    </section>

    <!-- PLATAFORMAS -->
    <section class="section bg-cinza">
      <div class="container">
        <div class="text-center">
          <span class="section-tag">Plataformas</span>
          <div class="divider"></div>
          <h2 class="section-title">Trabalhamos com as <span>melhores plataformas</span></h2>
        </div>
        <div class="cards-grid">
          <div class="card text-center">
            <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></div>
            <h3>NuvemShop</h3>
            <p>Parceiro oficial. Plataforma ideal para pequenos e médios negócios com ótimo custo-benefício.</p>
          </div>
          <div class="card text-center">
            <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
            <h3>Loja Integrada</h3>
            <p>Excelente para quem está começando. Integração nativa com marketplaces e frete.</p>
          </div>
          <div class="card text-center">
            <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
            <h3>Shopify</h3>
            <p>Plataforma global robusta ideal para quem quer escalar e vender internacionalmente.</p>
          </div>
          <div class="card text-center">
            <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1E73BE" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div>
            <h3>Tray Commerce</h3>
            <p>Parceiro oficial Tray. Ideal para médias e grandes lojas com necessidade de personalização avançada.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ETAPAS -->
    <section class="section">
      <div class="container">
        <div class="text-center">
          <span class="section-tag">Etapas</span>
          <div class="divider"></div>
          <h2 class="section-title">Nossa estratégia de <span>implantação</span></h2>
        </div>
        <div class="steps-grid">
          <div class="step-item"><div class="step-num">1</div><h3>Briefing</h3><p>Levantamento completo de necessidades, público-alvo, concorrência e objetivos do negócio.</p></div>
          <div class="step-item"><div class="step-num">2</div><h3>Arquitetura</h3><p>Definição de menus, categorias, filtros e estrutura da loja para máxima usabilidade.</p></div>
          <div class="step-item"><div class="step-num">3</div><h3>Design e Config</h3><p>Seleção e customização do tema, identidade visual, páginas institucionais e integrações.</p></div>
          <div class="step-item"><div class="step-num">4</div><h3>Produtos e Go Live</h3><p>Cadastro de produtos com fotos, descrições SEO, estratégia de preços e lançamento da loja.</p></div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
  <WhatsAppFloat />
</BaseLayout>
