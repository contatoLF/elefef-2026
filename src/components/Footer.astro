            </a>
          </div>
        </div>

        <!-- Nossa Agência -->
        <div>
          <h4 class="footer-col-title">Nossa Agência</h4>
          <ul class="footer-links">
            <li><a href="/quem-somos">Sobre Nós</a></li>
            <li><a href="/solucoes">Serviços</a></li>
            <li><a href="/orcamento">Solicitar Orçamento</a></li>
            <li><a href={`${WA}&text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20reuni%C3%A3o`} target="_blank" rel="noopener">Agendar Reunião</a></li>
            <li><a href="/blog">Blog</a></li>
          </ul>
        </div>

      </div>
    </div>
  </div>

  <!-- LINHA 3 — Rodapé inferior -->
  <div class="container">
    <div class="border-t border-white/[.07] py-5 flex flex-col md:flex-row items-center justify-between gap-2.5 flex-wrap">
      <p class="text-[13px] text-white/35">© 2026 Agência Elefef. Todos os Direitos Reservados.</p>
      <p class="text-[13px] text-white/35">
        WhatsApp: <a href={WA} class="text-white/50 hover:text-white transition-colors">+55 11 94063-5670</a>
      </p>
    </div>
  </div>

</footer>

<style>
  .footer-services {
    border-bottom: 1px solid rgba(255,255,255,.07);
    padding: 52px 0;
  }
  .footer-services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .footer-main {
    padding: 48px 0 40px;
    border-bottom: 1px solid rgba(255,255,255,.07);
  }
  .footer-main-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 60px;
    align-items: start;
  }

  .footer-col-title {
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #15E6F5;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }
  .footer-links li { margin-bottom: 10px; }
  .footer-links a {
    font-size: 14px;
    color: rgba(255,255,255,.65);
    transition: color .22s ease;
  }
  .footer-links a:hover { color: #fff; }

  .footer-social-btn {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: rgba(255,255,255,.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,.6);
    transition: background .22s ease, color .22s ease;
  }
  .footer-social-btn:hover { background: #15E6F5; color: #004d59; }

  @media (max-width: 900px) {
    .footer-services-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 640px) {
    .footer-services-grid { grid-template-columns: 1fr; }
    .footer-main-grid { grid-template-columns: 1fr; gap: 36px; }
  }
</style>
