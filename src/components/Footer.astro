    <div class="container">
      <div class="footer-main-grid">

        <!-- Logo + descrição + redes sociais -->
        <div>
          <div class="mb-3.5">
            <img src="/images/Copia-de-Copia-de-elefef.png" alt="Agência Elefef" class="h-[38px] w-auto" width="114" height="38" />
          </div>
          <p class="footer-desc">Agência especializada em gestão de tráfego pago e soluções para e-commerce. Transformamos cliques em clientes.</p>
          <div class="flex gap-2.5">
            <a href="https://www.instagram.com/elefef" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social-btn">
