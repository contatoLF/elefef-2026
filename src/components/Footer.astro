            <li><a href="/landing-page-eleitoral">Landing Page Eleitoral</a></li>
            <li><a href="/site-para-candidato-politico">Site para Candidato</a></li>
            <li><a href="/monitoramento-de-campanha-eleitoral-online">Monitoramento de Campanha</a></li>
          </ul>
        </div>

        <!-- Gestão de Tráfego -->
        <div>
          <h4 class="footer-col-title">Gestão de Tráfego</h4>
          <ul class="footer-links">
            <li><a href="/gestao-de-trafego">Visão Geral</a></li>
            <li><a href="/google-ads">Google Ads</a></li>
            <li><a href="/meta-ads">Meta Ads</a></li>
