            <li><a href="/amazon-ads">Amazon Ads</a></li>
            <li><a href="/bing-ads">Bing Ads</a></li>
            <li><a href="/globo-ads">Globo Ads</a></li>
          </ul>
        </div>

        <!-- E-commerce -->
        <div>
          <h4 class="footer-col-title">E-commerce</h4>
          <ul class="footer-links">
            <li><a href="/ecommerce">Visão Geral</a></li>
            <li><a href="/implantacao-ecommerce">Implantação</a></li>
            <li><a href="/consultoria-ecommerce">Consultoria</a></li>
            <li><a href="/suporte-evolucao">Suporte e Evolução</a></li>
