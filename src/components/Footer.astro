    <div class="container">
      <h2 class="text-white font-heading font-semibold mb-2" style="font-size:clamp(22px,3vw,30px);">
        Seu cliente ideal está a um clique de distância... <em class="not-italic text-ciano">Levamos ele até você!</em>
      </h2>
      <p class="text-white/80 text-base mb-7">Não perca mais tempo e dinheiro com campanhas que não entregam resultado.</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/orcamento" class="btn btn-ciano btn-lg">Solicite Orçamento</a>
        <a href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ26OVSaC3Wj8BBjx4Kyi_3huca82hVkME4HDNohzX53kWFc1EJ2sbNDVSHa8-nVmznITv0BbAxD" class="btn btn-outline btn-lg" target="_blank" rel="noopener">Agendar Reunião</a>
      </div>
    </div>
  </div>

  <!-- LINHA 1 — Serviços em 3 colunas -->
  <div class="footer-services">
    <div class="container">
      <div class="footer-services-grid">

        <!-- Marketing Político (carro chefe) -->
        <div>
          <h4 class="footer-col-title">Marketing Político</h4>
          <ul class="footer-links">
            <li><a href="/marketing-politico">Visão Geral</a></li>
            <li><a href="/trafego-pago-eleitoral-meta-ads">Tráfego Eleitoral — Meta Ads</a></li>
